# Claude API
ANTHROPIC_API_KEY=your_api_key_here

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# File upload limits
MAX_FILE_SIZE_MB=5

# Feature flags
ENABLE_GOOGLE_DOC_EXPORT=false

# Base URL (for shareable links)
NEXT_PUBLIC_BASE_URL=https://interviewrubric.com

# --- Async pipeline (Cloudflare Queues + R2) ---
# Server-side: the producer Worker URL the /api/jobs proxy forwards to.
# Set this after deploying the producer Worker. Leave unset to disable.
# Example: RUBRIC_PRODUCER_URL=https://rubric-producer.<your-account>.workers.dev
RUBRIC_PRODUCER_URL=

# Client-side: when "true", the UI uses the async pipeline (/api/jobs + polling).
# When unset or "false", the UI uses the original inline routes (/api/extract, /api/generate).
# Note: App Runner's build stage doesn't expose runtime env vars, so
# next.config.ts falls back to "true" if this isn't set at build time.
NEXT_PUBLIC_USE_ASYNC_PIPELINE=true
